<UserControl x:Class="MAAS_SFRThelper.Views.SphereDialog"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:local="clr-namespace:MAAS_SFRThelper.Views" 
       xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
       xmlns:converters="clr-namespace:MAAS_SFRThelper.Converters"
       mc:Ignorable="d"
       d:DesignHeight="700" d:DesignWidth="600" Background="White">

    <UserControl.Resources>
        <ResourceDictionary>
            <converters:boolVisibilityConverter x:Key="localVisibilityConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <!-- Mayo panel row -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Row 0: Target + Pattern -->
        <Label Height="26" Width="100" Margin="10" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Target" />
        <ComboBox Grid.Column="1" x:Name="TargetList" ItemsSource="{Binding TargetStructures}" SelectedItem="{Binding TargetSelected}" HorizontalAlignment="Left" Height="26" Margin="10" VerticalAlignment="Top" Width="123" Style="{x:Null}" />
        <Label Grid.Column="2" Height="26" Width="58" Margin="10" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Pattern" />

        <StackPanel Grid.Column="3" Margin="10">
            <RadioButton IsEnabled="{Binding PatternEnabled}" IsChecked="{Binding IsHex}" GroupName="Pattern" Margin="2">
                <Hyperlink NavigateUri="https://legacy.nimbios.org/~gross/bioed/webmodules/spherepacking.htm" RequestNavigate="Hyperlink_RequestNavigate">
                    Hexagonal Closest
                </Hyperlink>
            </RadioButton>
            <RadioButton IsEnabled="{Binding PatternEnabled}" IsChecked="{Binding IsRect}" GroupName="Pattern" Margin="2">
                <Hyperlink NavigateUri="https://chem.libretexts.org/Bookshelves/Physical_and_Theoretical_Chemistry_Textbook_Maps/Supplemental_Modules_(Physical_and_Theoretical_Chemistry)/Physical_Properties_of_Matter/States_of_Matter/Properties_of_Solids/Crystal_Lattice/Closest_Pack_Structures" RequestNavigate="Hyperlink_RequestNavigate">
                    Simple Cubic
                </Hyperlink>
            </RadioButton>
            <RadioButton IsEnabled="{Binding PatternEnabled}" IsChecked="{Binding IsRectAlt}" GroupName="Pattern" Margin="2">
                <Hyperlink NavigateUri="https://www.phiro.science/article/S2405-6316(24)00019-8/fulltext" RequestNavigate="Hyperlink_RequestNavigate">
                    Alternating Cubic
                </Hyperlink>
            </RadioButton>
            <RadioButton IsEnabled="{Binding PatternEnabled}" IsChecked="{Binding IsCVT3D}" GroupName="Pattern" Margin="2">
                <Hyperlink NavigateUri="https://www.ovito.org/docs/current/reference/pipelines/modifiers/voronoi_analysis.html" RequestNavigate="Hyperlink_RequestNavigate">
                    CVT3D
                </Hyperlink>
            </RadioButton>
            <RadioButton IsEnabled="{Binding PatternEnabled}" IsChecked="{Binding IsMayo}" GroupName="Pattern" Margin="2">
                <Hyperlink NavigateUri="https://doi.org/10.1088/1361-6560/ad2ee8" RequestNavigate="Hyperlink_RequestNavigate">
                    Mayo MC
                </Hyperlink>
            </RadioButton>
        </StackPanel>

        <!-- Row 1: Radius + Spacing -->
        <Label Grid.Row="1" Height="26" Width="100" Margin="10" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Radius (mm)" />
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="Radius" Text="{Binding Radius}" HorizontalAlignment="Left" Height="26" Margin="10" VerticalAlignment="Top" Width="123" Style="{x:Null}"/>
        <Label Grid.Row="1" Grid.Column="2" Height="26" Width="100" Margin="10" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Spacing (mm)" />
        <ComboBox Grid.Row="1" Grid.Column="3" x:Name="SpacingCombo" ItemsSource="{Binding ValidSpacings}" SelectedItem="{Binding SpacingSelected}" IsEnabled="{Binding SpacingEnabled}" HorizontalAlignment="Left" Height="26" Margin="10" VerticalAlignment="Top" Width="123" />

        <!-- Row 2: Partial sphere slider + Checkboxes -->
        <StackPanel Grid.Row="2" Grid.ColumnSpan="2">
            <Slider Value="{Binding VThresh}" Minimum="0" Maximum="100" IsEnabled="{Binding ThresholdEnabled}" ToolTip="{Binding VThresh}" Style="{x:Null}"/>
            <Label VerticalAlignment="Top" HorizontalAlignment="Center" Content="{Binding PartialSphereText}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2">
            <CheckBox IsEnabled="{Binding SingleSphereEnabled}" Margin="5" IsChecked="{Binding CreateSingle}" Style="{x:Null}">Create spheres as single structure only</CheckBox>
            <CheckBox IsEnabled="{Binding NullVoidsEnabled}" Margin="5" IsChecked="{Binding CreateNullsVoids}" Style="{x:Null}">Create void structures</CheckBox>
        </StackPanel>

        <!-- Row 3: XY Shift -->
        <Label Grid.Row="3" Height="26" Margin="10" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Lattice X Shift (mm)" />
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="XShift" Text="{Binding XShift}" IsEnabled="{Binding ShiftEnabled}" HorizontalAlignment="Left" Height="26" Margin="10" VerticalAlignment="Top" Width="123" Style="{x:Null}"/>
        <Label Grid.Row="3" Grid.Column="2" Height="26" Margin="10" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Lattice Y Shift (mm)" />
        <TextBox Grid.Row="3" Grid.Column="3" x:Name="Yshift" Text="{Binding YShift}" IsEnabled="{Binding ShiftEnabled}" HorizontalAlignment="Left" Height="26" Margin="10" VerticalAlignment="Top" Width="123" Style="{x:Null}"/>

        <!-- Row 4: Lateral Scaling + Create/Export buttons -->
        <Label Grid.Row="4" Height="26" Width="180" Margin="10" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Lateral spacing factor" Visibility="{Binding LSFVisibility, Converter={StaticResource localVisibilityConverter}}" />
        <TextBox Grid.Row="4" Grid.Column="1" x:Name="LateralScalingFactor" Text="{Binding LateralScalingFactor}" HorizontalAlignment="Left" Height="26" Margin="11,10,0,0" VerticalAlignment="Top" Width="123" Style="{x:Null}" Visibility="{Binding LSFVisibility, Converter={StaticResource localVisibilityConverter}}" />

        <StackPanel Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Height="26" Margin="10" Width="123"
                    HorizontalAlignment="Left" VerticalAlignment="Top" 
                    Content="Create" Command="{Binding CreateLatticeCommand}" Style="{x:Null}" />

                <Button Grid.Column="1" Height="26" Margin="10" Width="123"
                    HorizontalAlignment="Left" VerticalAlignment="Top" 
                    Content="Export Data" Command="{Binding ExportDataCommand}"
                    IsEnabled="{Binding DataReadyForExport}" Style="{x:Null}" />
            </Grid>

            <TextBlock Foreground="red" Text="{Binding LatticeValidationText}"
                Visibility="{Binding LVVis, Converter={StaticResource localVisibilityConverter}}" />
        </StackPanel>

        <!-- Row 5: Mayo Parameters Panel (visible only when Mayo MC selected) -->
        <Border Grid.Row="5" Grid.ColumnSpan="4" Margin="10,5,10,5"
                BorderBrush="LightGray" BorderThickness="1" CornerRadius="3" Padding="8"
                Visibility="{Binding MayoPanelVisible, Converter={StaticResource localVisibilityConverter}}">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" Margin="0,0,0,5" Text="Mayo MC Parameters (Deufel et al. 2024)"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- OAR Selection -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,5">
                        <TextBlock Text="Avoidance OARs:" Margin="0,0,0,3"/>
                        <ListBox ItemsSource="{Binding MayoAvailableOars}"
                                 SelectionMode="Multiple" Height="80"
                                 Style="{x:Null}"
                                 SelectionChanged="MayoOarListBox_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="2"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </StackPanel>

                    <!-- Centralization + Gradient Walk + Seed -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,5">
                        <TextBlock Text="Centralization pressure:" Margin="0,0,0,3"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="35"/>
                            </Grid.ColumnDefinitions>
                            <Slider Value="{Binding MayoCentralization}" 
                                    Minimum="0" Maximum="1" 
                                    TickFrequency="0.1" IsSnapToTickEnabled="True"
                                    Style="{x:Null}"/>
                            <TextBlock Grid.Column="1" Text="{Binding MayoCentralization, StringFormat={}{0:F1}}" 
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>

                        <CheckBox Margin="0,5,0,3" IsChecked="{Binding MayoUseGradientWalk}" Style="{x:Null}">
                            Gradient walk to center
                        </CheckBox>

                        <Grid Margin="0,3,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Seed:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBox Grid.Column="1" Text="{Binding MayoRandomSeed}" 
                                     Style="{x:Null}" Height="22"/>
                        </Grid>
                    </StackPanel>

                    <!-- Advanced Settings Expander -->
                    <Expander Grid.Row="1" Grid.ColumnSpan="2" Header="Advanced Constraints" 
                              Margin="0,5,0,0" IsExpanded="{Binding MayoShowAdvanced}">
                        <Grid Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="GTV margin (mm):" 
                                       VerticalAlignment="Center" Margin="0,2"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding MayoDGtv}" 
                                     Style="{x:Null}" Height="22" Margin="5,2"/>

                            <TextBlock Grid.Row="0" Grid.Column="3" Text="OAR margin (mm):" 
                                       VerticalAlignment="Center" Margin="0,2"/>
                            <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding MayoDOar}" 
                                     Style="{x:Null}" Height="22" Margin="5,2"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Min spacing (mm):" 
                                       VerticalAlignment="Center" Margin="0,2"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MayoDCenter}" 
                                     Style="{x:Null}" Height="22" Margin="5,2"/>

                            <TextBlock Grid.Row="1" Grid.Column="3" Text="Z-sep (mm):" 
                                       VerticalAlignment="Center" Margin="0,2"/>
                            <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding MayoZSep}" 
                                     Style="{x:Null}" Height="22" Margin="5,2"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Co-axial (mm):" 
                                       VerticalAlignment="Center" Margin="0,2"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MayoDCoAxial}" 
                                     Style="{x:Null}" Height="22" Margin="5,2"/>
                        </Grid>
                    </Expander>

                    <!-- Mayo Status -->
                    <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding MayoStatusText}" 
                               Foreground="Gray" Margin="0,3,0,0" TextWrapping="Wrap"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Row 6: Progress bar -->
        <ProgressBar Grid.Row="6" Margin="10" Maximum="100" Minimum="0" Value="{Binding ProgressValue}"
                     Grid.ColumnSpan="4" Height="20"/>

        <!-- Row 7: Output text -->
        <ScrollViewer Grid.Row="7" Grid.ColumnSpan="4" Margin="10" VerticalScrollBarVisibility="Auto" MaxHeight="200">
            <TextBlock Text="{Binding Output}" TextWrapping="Wrap"/>
        </ScrollViewer>

    </Grid>
</UserControl>